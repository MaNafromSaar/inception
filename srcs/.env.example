# ============================================================================
# INCEPTION PROJECT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Usage:
#   On your VM, rename (or copy) this file to srcs/.env and fill in the
#   password placeholders with your real credentials:
#
#   cp srcs/.env.example srcs/.env
#   vim srcs/.env
#
# The Makefile will also create srcs/.env automatically from this file if it
# is missing, but always set your own passwords before running make.
# ============================================================================

# --- Domain Name ---
DOMAIN_NAME=mnaumann.42.fr

# --- MariaDB Credentials ---
MYSQL_DATABASE=wordpress_db
MYSQL_USER=wp_user
MYSQL_PASSWORD=your_database_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here

# --- WordPress → Database Connection ---
# These must match the MariaDB values above exactly.
# Note: variable references like ${MYSQL_DATABASE} are NOT expanded by docker
# compose when read via env_file, so explicit values are required here.
WP_DB_HOST=mariadb
WP_DB_NAME=wordpress_db
WP_DB_USER=wp_user
WP_DB_PASSWORD=your_database_password_here

# --- WordPress Salts ---
# Generate fresh values from: https://api.wordpress.org/secret-key/1.1/salt/
AUTH_KEY='put your unique phrase here'
SECURE_AUTH_KEY='put your unique phrase here'
LOGGED_IN_KEY='put your unique phrase here'
NONCE_KEY='put your unique phrase here'
AUTH_SALT='put your unique phrase here'
SECURE_AUTH_SALT='put your unique phrase here'
LOGGED_IN_SALT='put your unique phrase here'
NONCE_SALT='put your unique phrase here'

# --- WordPress Site Details ---
# WP_SITE_URL must match DOMAIN_NAME above (with https:// prefix).
WP_SITE_URL=https://mnaumann.42.fr
WP_SITE_TITLE="Inception Project"

# --- WordPress Admin User ---
# WARNING: Admin username must NOT contain 'admin' or 'administrator'
WP_ADMIN_USER=wpsudo
WP_ADMIN_PASSWORD=your_admin_password_here
WP_ADMIN_EMAIL=admin@mnaumann.42.fr

# --- WordPress Second User ---
WP_USER_USER=wpuser
WP_USER_PASSWORD=your_user_password_here
WP_USER_EMAIL=user@mnaumann.42.fr

# --- FTP Configuration ---
FTP_USER=ftpuser
FTP_PASS=your_ftp_password_here

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
